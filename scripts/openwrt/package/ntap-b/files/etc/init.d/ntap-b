#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

BIN="/usr/sbin/ntap-b"
RUN_DIR="/var/run/ntap"
RUN_CONF="$RUN_DIR/ntap-b.conf"

write_runtime_conf() {
	config_get_bool enabled node enabled 0
	[ "$enabled" = "1" ] || return 1

	config_get server_addr node server_addr
	config_get node_id node node_id
	config_get node_key node node_key
	config_get tap_name node tap_name "ntap-b0"
	config_get mtu node mtu "1400"
	config_get log_level node log_level "info"
	config_get log_file node log_file "/tmp/ntap-b.log"

	if [ -z "$server_addr" ] || [ -z "$node_id" ] || [ -z "$node_key" ]; then
		echo "ntap-b: server_addr, node_id, and node_key are required" >&2
		return 2
	fi

	mkdir -p "$RUN_DIR"
	cat > "$RUN_CONF" <<EOF
[node]
server_addr=$server_addr
node_id=$node_id
node_key=$node_key

[tap]
tap_name=$tap_name
mtu=$mtu

[log]
level=$log_level
file=$log_file
EOF
	return 0
}

start_service() {
	config_load ntap-b
	write_runtime_conf
	rc=$?
	[ "$rc" = "1" ] && return 0
	[ "$rc" = "0" ] || return "$rc"

	procd_open_instance
	procd_set_param command "$BIN" -c "$RUN_CONF" run --tap
	procd_set_param respawn 5 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger ntap-b
}
